{
  "template_version": 1,
  "structure": {
    "phases": [
      {
        "name": "Foundation",
        "focus": "Core concepts and prerequisites",
        "topic_template": {
          "pattern": ["intro", "setup", "basics"],
          "estimated_minutes_per_topic": 15
        },
        "min_topics": 2,
        "max_topics": 5
      },
      {
        "name": "Core",
        "focus": "Primary functionality and main concepts",
        "topic_template": {
          "pattern": ["main_concept_1", "main_concept_2", "integration"],
          "estimated_minutes_per_topic": 25
        },
        "min_topics": 3,
        "max_topics": 8
      },
      {
        "name": "Advanced",
        "focus": "Deep understanding and best practices",
        "topic_template": {
          "pattern": ["advanced_1", "advanced_2", "best_practices", "optimization"],
          "estimated_minutes_per_topic": 30
        },
        "min_topics": 2,
        "max_topics": 6
      },
      {
        "name": "Practice",
        "focus": "Hands-on application and real-world scenarios",
        "topic_template": {
          "pattern": ["mini_project", "real_world_scenario", "debugging"],
          "estimated_minutes_per_topic": 45
        },
        "min_topics": 1,
        "max_topics": 3
      }
    ]
  },
  "plan_types": {
    "new_topic": {
      "description": "Learning a new technology, language, or concept",
      "phases": ["Foundation", "Core", "Advanced", "Practice"],
      "requires_context": false
    },
    "codebase": {
      "description": "Understanding an existing codebase",
      "phases": ["Foundation", "Core", "Advanced"],
      "requires_context": true,
      "context_focus": ["structure", "patterns", "key_modules"]
    },
    "build": {
      "description": "Building something from scratch",
      "phases": ["Foundation", "Core", "Practice"],
      "requires_context": false,
      "output_focus": ["project_setup", "core_features", "polish"]
    },
    "understand_only": {
      "description": "Quick understanding without deep learning",
      "phases": ["Foundation", "Core"],
      "requires_context": true,
      "depth": "shallow"
    }
  },
  "experience_level_adjustments": {
    "beginner": {
      "phase_multiplier": 1.5,
      "include_prerequisites": true,
      "more_examples": true,
      "estimated_time_multiplier": 2
    },
    "intermediate": {
      "phase_multiplier": 1.0,
      "include_prerequisites": false,
      "balanced_examples": true,
      "estimated_time_multiplier": 1
    },
    "advanced": {
      "phase_multiplier": 0.7,
      "skip_basics": true,
      "focus_advanced": true,
      "estimated_time_multiplier": 0.5
    }
  },
  "timeline_adjustments": {
    "hours_per_week_1-2": {
      "compression": 0.5,
      "skip_phase": ["Advanced"],
      "focus": "essentials"
    },
    "hours_per_week_3-5": {
      "compression": 1.0,
      "include_all_phases": true,
      "focus": "balanced"
    },
    "hours_per_week_6-10": {
      "compression": 1.5,
      "include_all_phases": true,
      "add_extra_practice": true,
      "focus": "thorough"
    },
    "by_date_urgent": {
      "compression": 0.3,
      "skip_phase": ["Foundation", "Advanced"],
      "focus": "survival"
    }
  },
  "dynamic_generation": {
    "sources": {
      "user_goals": {
        "weight": 0.4,
        "extraction": "parse_goals_from_user_input"
      },
      "codebase_analysis": {
        "weight": 0.3,
        "extraction": "analyze_modules_and_patterns",
        "only_for_types": ["codebase", "understand_only"]
      },
      "standard_curriculum": {
        "weight": 0.3,
        "extraction": "topic_based_standard_topics"
      }
    },
    "topic_generation": {
      "method": "llm_or_template",
      "fallback": "use_topic_patterns",
      "validation": "check_coverage_of_goals"
    }
  },
  "examples": {
    "new_topic_python": {
      "Foundation": [
        {"task_id": "1.1", "title": "What is Python?", "category": "foundation"},
        {"task_id": "1.2", "title": "Installation & Setup", "category": "foundation"},
        {"task_id": "1.3", "title": "Basic Syntax & Variables", "category": "foundation"}
      ],
      "Core": [
        {"task_id": "2.1", "title": "Functions & Scope", "category": "core"},
        {"task_id": "2.2", "title": "Lists & Data Structures", "category": "core"},
        {"task_id": "2.3", "title": "Control Flow & Loops", "category": "core"}
      ]
    },
    "codebase_example": {
      "Foundation": [
        {"task_id": "1.1", "title": "Project Structure Overview", "category": "foundation"},
        {"task_id": "1.2", "title": "Entry Points & Configuration", "category": "foundation"}
      ],
      "Core": [
        {"task_id": "2.1", "title": "Key Module: auth", "category": "core"},
        {"task_id": "2.2", "title": "Key Module: api", "category": "core"},
        {"task_id": "2.3", "title": "Data Flow & Patterns", "category": "core"}
      ]
    }
  }
}